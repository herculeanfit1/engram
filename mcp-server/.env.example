# Engram API (required)
ENGRAM_URL=http://btai-tk-engram:3700

# Transport: "stdio" for Claude Desktop local, "http" for Docker/remote
TRANSPORT=stdio
PORT=3800

# API key auth (required for HTTP transport)
# Format: "label1:key1,label2:key2"
# MCP_API_KEYS=claude:changeme,n8n:changeme

# Logging
AUDIT_LOG_LEVEL=info
NODE_ENV=production
